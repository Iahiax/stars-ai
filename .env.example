# ══════════════════════════════════════════════════════════════
#  Stars AI — ملف الإعدادات النموذجي
#  انسخ هذا الملف إلى .env وأضف مفاتيحك
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── مفاتيح APIs النماذج ──────────────────────────────────────

# OpenAI (GPT-4, GPT-3.5)
# احصل عليه من: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# احصل عليه من: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini)
# احصل عليه من: aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Mistral AI
# احصل عليه من: console.mistral.ai/api-keys
MISTRAL_API_KEY=...

# DeepSeek
# احصل عليه من: platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# xAI (Grok)
XAI_API_KEY=xai-...

# ── HuggingFace ───────────────────────────────────────────────

# للوصول لنماذج Llama المحمية + رفع النماذج
# احصل عليه من: huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ── Weights & Biases (تتبع التدريب) ──────────────────────────

# احصل عليه من: wandb.ai/settings
WANDB_API_KEY=...

# اسم مشروعك في wandb (اختياري)
WANDB_PROJECT=stars-ai

# ── Google Cloud (اختياري — لـ Secret Manager) ───────────────

# معرّف مشروع GCP
GCP_PROJECT_ID=your-project-id

# مسار ملف بيانات الاعتماد (Service Account Key)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# ── إعدادات النموذج الافتراضية ───────────────────────────────

# النموذج الأساسي للتدريب (يمكن تغييره في train_all.py)
# BASE_MODEL=microsoft/phi-2
# BASE_MODEL=mistralai/Mistral-7B-v0.1
# BASE_MODEL=meta-llama/Meta-Llama-3-8B

# مجلد حفظ النماذج
# MODELS_DIR=./models

# ── إعدادات التدريب الافتراضية ───────────────────────────────

# استخدام GPU (تلقائي إذا لم تحدد)
# CUDA_VISIBLE_DEVICES=0

# تعطيل tokenizers parallelism (يحل مشاكل بعض الأجهزة)
TOKENIZERS_PARALLELISM=false

# ── ملاحظة ───────────────────────────────────────────────────
# لا ترفع ملف .env على GitHub!
# أضف .env إلى .gitignore دائماً
